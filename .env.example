# LLM Providers (optional here if set in OS env instead)
GROQ_API_KEY= # from https://console.groq.com/keys
OPENROUTER_API_KEY= # from https://openrouter.ai/keys

# Local models
OLLAMA_HOST=http://localhost:11434

# Default provider: groq | ollama | openrouter
DEFAULT_PROVIDER=groq

# App config
LOG_LEVEL=INFO

# Hugging Face Hub (optional; higher rate limits for sentence-transformers downloads)
HF_TOKEN= # from https://huggingface.co/settings/tokens (Read)

# --- Langfuse app client (SDK / Settings) ---
LANGFUSE_SECRET_KEY= # from Langfuse UI → Project → API Keys (sk-lf-...)
LANGFUSE_PUBLIC_KEY= # from Langfuse UI → Project → API Keys (pk-lf-...)
# SDK prefers LANGFUSE_BASE_URL; Settings also accepts LANGFUSE_HOST
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_HOST=http://localhost:3000

# --- Langfuse Docker Compose (official stack; same folder as docker-compose.yml) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET= # python -c "import secrets; print(secrets.token_hex(32))"
SALT= # secrets.token_hex(16)
ENCRYPTION_KEY= # secrets.token_hex(32) — must be 64 hex chars

POSTGRES_USER=postgres
POSTGRES_PASSWORD= # secrets.token_hex(16)
POSTGRES_DB=postgres
# Host 'postgres' is the Compose service name (not localhost).
# Paste the same password as POSTGRES_PASSWORD (no angle brackets).
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/postgres

CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD= # secrets.token_hex(16)

REDIS_AUTH= # secrets.token_hex(16)

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD= # secrets.token_hex(16)
# Must match MINIO_ROOT_PASSWORD for all three:
LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=minio
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=
LANGFUSE_S3_MEDIA_UPLOAD_ACCESS_KEY_ID=minio
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=
LANGFUSE_S3_BATCH_EXPORT_ACCESS_KEY_ID=minio
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=

# Headless init (optional; skip signup on first boot)
LANGFUSE_INIT_USER_EMAIL=admin@nexusdoc.local
LANGFUSE_INIT_USER_NAME=admin
LANGFUSE_INIT_USER_PASSWORD=nexusdoc-dev
LANGFUSE_INIT_ORG_ID=nexusdoc-org
LANGFUSE_INIT_ORG_NAME=NexusDoc
LANGFUSE_INIT_PROJECT_ID=nexusdoc-project
LANGFUSE_INIT_PROJECT_NAME=NexusDoc Local

# Database (later phases; optional for Phase 1)
SUPABASE_URL= # from https://supabase.com dashboard
SUPABASE_SERVICE_KEY= # from Supabase project settings
