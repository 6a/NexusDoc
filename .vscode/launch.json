{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Phase 1: Verify All",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/phase1_verify.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "Phase 1: Hello RAG Traced",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/hello_rag_traced.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "Phase 1: Test LangFuse",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/test_langfuse.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "Run Tests (all)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/", "-v"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    }
  ]
}
